# Copy this to .env and fill in your values
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL blank to use SQLite locally (perfect for development)
# For production (Railway/Render), they set this automatically
DATABASE_URL=

